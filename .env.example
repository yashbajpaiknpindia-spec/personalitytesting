# ─── Database (Render PostgreSQL) ────────────────────────────────────────────
# Auto-set by Render when linked — do NOT set manually in Render dashboard
DATABASE_URL="postgresql://user:password@host:5432/brandsyndicate"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://your-app.onrender.com"
NEXTAUTH_SECRET="generate: openssl rand -base64 32"
NEXT_PUBLIC_APP_URL="https://your-app.onrender.com"

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Webhook secret: Razorpay Dashboard → Webhooks → add endpoint → copy secret
RAZORPAY_WEBHOOK_SECRET=""

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="studio@brandsyndicate.co"

# ─── Pexels (presentation slide images) ──────────────────────────────────────
PEXELS_API_KEY=""

# ─── Cron security ────────────────────────────────────────────────────────────
CRON_SECRET="generate: openssl rand -base64 24"
