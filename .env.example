# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/brandsyndicate"

# ── NextAuth v5 (PRIMARY names — use these) ───────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# Must be bare origin only — NO trailing path like /generate
AUTH_URL="https://www.brandsyndicate.in"

# ── NextAuth v4 compat aliases (also accepted as fallback) ────────────────────
NEXTAUTH_SECRET="same-value-as-AUTH_SECRET"
NEXTAUTH_URL="https://www.brandsyndicate.in"

# ── App URL (used in emails, QR codes, public links) ─────────────────────────
NEXT_PUBLIC_APP_URL="https://www.brandsyndicate.in"

# ── Anthropic Claude AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Razorpay (payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# ── Cloudinary (server-side image uploads) ────────────────────────────────────
# IMPORTANT: Do NOT use NEXT_PUBLIC_ prefix here. These are server secrets.
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Cloudinary upload preset (public — used client-side) ─────────────────────
NEXT_PUBLIC_CLOUDINARY_PRESET="brandsyndicate"

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="hello@brandsyndicate.in"

# ── Pexels (stock images for slides) ──────────────────────────────────────────
PEXELS_API_KEY="your-pexels-key"

# ── Cron security token ───────────────────────────────────────────────────────
CRON_SECRET="your-cron-secret"

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD="your-admin-password"
ADMIN_PHONE="your-phone"

# ── Puppeteer (skip Chromium download — use system Chrome) ────────────────────
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_SKIP_DOWNLOAD=true

# ── Custom domain CNAME target ────────────────────────────────────────────────
CNAME_TARGET="cname.brandsyndicate.in"

# ── Google AdSense ────────────────────────────────────────────────────────────
# Get your publisher ID from adsense.google.com → Account → Account information
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-XXXXXXXXXXXXXXXX"
# Get slot IDs from AdSense → Ads → By ad unit → Create ad unit
NEXT_PUBLIC_ADSENSE_ARTICLE_SLOT="XXXXXXXXXX"    # Article pages (mid-content + bottom)
NEXT_PUBLIC_ADSENSE_GUIDES_SLOT="XXXXXXXXXX"     # Guides listing page
NEXT_PUBLIC_ADSENSE_RESOURCES_SLOT="XXXXXXXXXX"  # Resources listing page

# ── Contact form recipient email ─────────────────────────────────────────────
CONTACT_EMAIL="hello@brandsyndicate.in"
