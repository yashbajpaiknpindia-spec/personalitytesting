generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  TEAM
}

enum Role {
  USER
  ADMIN
}

enum ExportFormat {
  PDF
  PPTX
  HTML
  VCARD
  QR
}

enum GenStatus {
  PENDING
  COMPLETE
  FAILED
  FLAGGED
}

// Phase 1: analytics event types
enum EventType {
  PORTFOLIO_VIEW
  CARD_VIEW
  RESUME_DOWNLOAD
  PRESENTATION_VIEW
  LEAD_CAPTURED
}

// ── Core models (original, unchanged) ────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  name          String?
  username      String?  @unique
  image         String?
  role          Role     @default(USER)
  plan          Plan     @default(FREE)
  jobTitle      String?
  company       String?
  location      String?
  website       String?
  linkedin      String?
  bio           String?
  accentColor   String?  @default("#C9A84C")
  usageCount    Int      @default(0)
  usageResetAt  DateTime @default(now())
  razorpayId    String?  @unique
  razorpaySubId String?
  onboarded     Boolean  @default(false)
  referralCode  String?  @unique
  referredBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  generations     Generation[]
  exports         Export[]
  portfolio        Portfolio?
  contacts         Contact[]
  cardViews        CardView[]
  analyticsEvents  AnalyticsEvent[]
  socialLinks      SocialLinks?
  domain           Domain?
  resumeVersions   ResumeVersion[]
  presentations    Presentation[]
  projects         Project[]
  seoSettings      SeoSettings?
  blogPosts        BlogPost[]
}

model Template {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String
  tier        String
  description String?
  accentColor String   @default("#C9A84C")
  preview     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  generations Generation[]
}

model Generation {
  id           String    @id @default(cuid())
  userId       String
  templateId   String
  status       GenStatus @default(PENDING)
  inputData    Json
  enrichedData Json?
  outputData   Json?
  tokenCount   Int?
  flagReason   String?
  version      Int       @default(1)
  parentId     String?
  createdAt    DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template  Template  @relation(fields: [templateId], references: [id])
  exports   Export[]
  portfolio Portfolio?
}

model Export {
  id            String       @id @default(cuid())
  userId        String
  generationId  String
  format        ExportFormat
  cloudinaryId  String?
  url           String?
  expiresAt     DateTime?
  downloadCount Int          @default(0)
  createdAt     DateTime     @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

// ── Phase 1: Portfolio Publishing ─────────────────────────────────────────

model Portfolio {
  id             String   @id @default(cuid())
  userId         String   @unique
  generationId   String   @unique
  slug           String   @unique
  isPublished    Boolean  @default(true)
  customDomain   String?
  seoTitle       String?
  seoDescription String?
  ogImageUrl     String?
  viewCount      Int      @default(0)
  publishedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

// ── Phase 1: Lead Capture ─────────────────────────────────────────────────

model Contact {
  id         String   @id @default(cuid())
  ownerId    String
  name       String
  email      String
  phone      String?
  company    String?
  sourceSlug String?
  createdAt  DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model CardView {
  id        String   @id @default(cuid())
  ownerId   String
  visitorIp String?
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

// ── Phase 1: Analytics ────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String    @id @default(cuid())
  ownerId   String
  type      EventType
  metadata  Json?
  visitorIp String?
  userAgent String?
  referer   String?
  createdAt DateTime  @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

// ── Phase 2: Social Links ─────────────────────────────────────────────────

model SocialLinks {
  id        String   @id @default(cuid())
  userId    String   @unique
  linkedin  String?
  whatsapp  String?
  instagram String?
  website   String?
  portfolio String?
  twitter   String?
  github    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Phase 2: Custom Domain ────────────────────────────────────────────────

model Domain {
  id                String   @id @default(cuid())
  userId            String   @unique
  domain            String   @unique
  verified          Boolean  @default(false)
  verificationToken String
  cnameTarget       String   @default("cname.brandsyndicate.co")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Phase 5: Living Portfolio ──────────────────────────────────────────────

model Project {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  url         String?
  imageUrl    String?
  tags        String[]  @default([])
  featured    Boolean   @default(false)
  order       Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, featured])
  @@index([userId, order])
  @@map("projects")
}

model SeoSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  pageTitle       String?
  metaDescription String?
  ogImageUrl      String?
  twitterHandle   String?
  canonicalUrl    String?
  noIndex         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seo_settings")
}

model BlogPost {
  id             String    @id @default(cuid())
  userId         String
  title          String
  slug           String
  excerpt        String?
  content        String    @default("")
  coverImageUrl  String?
  tags           String[]  @default([])
  published      Boolean   @default(false)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  readingMinutes Int?      @default(1)
  viewCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
  @@index([userId, published])
  @@index([publishedAt(sort: Desc)])
  @@map("blog_posts")
}

// ── Phase 4: Editable Slide Builder ───────────────────────────────────────

model Presentation {
  id          String   @id @default(cuid())
  userId      String
  title       String   @default("Untitled Presentation")
  slug        String   @unique
  accentColor String   @default("#C9A84C")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  slides Slide[]

  @@index([userId])
  @@map("presentations")
}

model Slide {
  id             String   @id @default(cuid())
  presentationId String
  order          Int      @default(0)
  content        Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@index([presentationId])
  @@index([presentationId, order])
  @@map("slides")
}

// ── Phase 3: Resume Intelligence ──────────────────────────────────────────

model ResumeVersion {
  id             String   @id @default(cuid())
  userId         String
  originalResume Json
  tailoredResume Json?
  jobDescription String?
  coverLetter    String?
  atsScore       Int?
  atsBreakdown   Json?
  atsSuggestions Json?
  tone           String?  @default("professional")
  label          String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}
